<%- include('../partials/navback') %>
<!-- Admin Dashboard with Contestant CRUD -->

<main class="container mx-auto px-4 pt-20 pb-16">

    <section class="container admin-dashboard">
        <div class="dashboard-header">
            <div class="dashboard-actions">
                
                <!-- <a href="/users" class="action-btn users-btn">
                    <span class="action-icon">👥</span>
                    <span class="action-text">Manage Users</span>
                </a> -->
                <button onclick="openAddContestantModal()" class="action-btn add-contestant-btn">
                    <span class="action-icon">➕</span>
                    <span class="action-text">Add Contestant</span>
                </button>
            </div>
        </div>
    
        <div class="dashboard-stats">
            <div class="stat-card">
                <div class="stat-icon total-users">
                    <span>👥</span>
                </div>
                <div class="stat-content">
                    <h3 class="stat-number"><%= stats?.totalUsers || 0 %></h3>
                    <p class="stat-label">Total Users</p>
                </div>
                <div class="stat-trend">
                    <span class="trend-up">+12%</span>
                    <span>this month</span>
                </div>
            </div>
    
            <div class="stat-card">
                <div class="stat-icon total-messages">
                    <span>💬</span>
                </div>
                <div class="stat-content">
                    <h3 class="stat-number"><%= stats?.totalMessages || 0 %></h3>
                    <p class="stat-label">Total Messages</p>
                </div>
                <div class="stat-trend">
                    <span class="trend-up">+25%</span>
                    <span>this month</span>
                </div>
            </div>
    
            <div class="stat-card">
                <div class="stat-icon unread-messages">
                    <span>🗳️</span>
                </div>
                <div class="stat-content">
                    <h3 class="stat-number"><%= stats?.totalVotes || 0 %></h3>
                    <p class="stat-label">Total Votes</p>
                </div>
                <div class="stat-trend">
                    <span class="trend-up">+15%</span>
                    <span>this week</span>
                </div>
            </div>
    
            <div class="stat-card">
                <div class="stat-icon recent-activity">
                    <span>📊</span>
                </div>
                <div class="stat-content">
                    <h3 class="stat-number"><%= stats?.activeUsers || 0 %></h3>
                    <p class="stat-label">Active Users</p>
                </div>
                <div class="stat-trend">
                    <span class="trend-up">+8%</span>
                    <span>today</span>
                </div>
            </div>
        </div>
    
        <!-- Contestants Management Section -->
        <div class="dashboard-section contestants-section">
            <div class="section-header">
                <h3 class="section-title">
                    <span class="section-icon">🎭</span>
                    Manage Contestants
                </h3>
                <button onclick="openAddContestantModal()" class="section-link add-btn">
                    + Add New
                </button>
            </div>
            <div class="section-content" id="contestants-list">
                <!-- Contestants will be loaded here -->
                <div class="loading-spinner">Loading contestants...</div>
            </div>
        </div>
    </section>
</main>

<!-- Add Contestant Modal -->
<div id="addContestantModal" class="modal hidden" style="color: #fff;" >
    <div class="modal-content">
        <div class="modal-header">
            <h3 class="modal-title">Add New Contestant</h3>
            <button onclick="closeAddContestantModal()" class="close-btn">&times;</button>
        </div>
        <div class="modal-body" >
            <form id="addContestantForm" onsubmit="addContestant(event)">
                <div class="form-group">
                    <label for="name" >Name</label>
                    <input type="text" id="name" name="name" required placeholder="Enter contestant name">
                </div>
                <div class="form-group">
                    <label for="contestantNumber">Contestant Number</label>
                    <input type="text" id="contestantNumber" name="contestantNumber" required placeholder="e.g., 001">
                </div>
                <div class="form-group">
                    <label for="bio">Bio</label>
                    <textarea id="bio" name="bio" rows="4" required placeholder="Enter contestant biography"></textarea>
                </div>
                <div class="form-group">
                    <label for="imageUrl">Image name</label>
                    <input type="text" id="imageUrl" name="imageUrl" placeholder="image.jpg">
                </div>
                <div class="modal-actions">
                    <button type="button" onclick="closeAddContestantModal()" class="cancel-btn">Cancel</button>
                    <button type="submit" class="submit-btn">Add Contestant</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Contestant Modal -->
<div id="editContestantModal" class="modal hidden" style="color: #fff;">
    <div class="modal-content">
        <div class="modal-header">
            <h3 class="modal-title">Edit Contestant</h3>
            <button onclick="closeEditContestantModal()" class="close-btn">&times;</button>
        </div>
        <div class="modal-body">
            <form id="editContestantForm" onsubmit="editContestant(event)">
                <input type="hidden" id="editId" name="id">
                <div class="form-group">
                    <label for="editName">Name</label>
                    <input type="text" id="editName" name="name" required placeholder="Enter contestant name">
                </div>
                <div class="form-group">
                    <label for="editContestantNumber">Contestant Number</label>
                    <input type="text" id="editContestantNumber" name="contestantNumber" required placeholder="e.g., 001">
                </div>
                <div class="form-group">
                    <label for="editBio">Bio</label>
                    <textarea id="editBio" name="bio" rows="4" required placeholder="Enter contestant biography"></textarea>
                </div>
                <div class="form-group">
                    <label for="editImageUrl">Image name</label>
                    <input type="text" id="editImageUrl" name="imageUrl" placeholder="image.jpg">
                </div>
                <div class="modal-actions">
                    <button type="button" onclick="closeEditContestantModal()" class="cancel-btn">Cancel</button>
                    <button type="submit" class="submit-btn">Update Contestant</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div id="deleteContestantModal" class="modal hidden"style="color: #fff;" >
    <div class="modal-content delete-modal">
        <div class="modal-header delete-header">
            <h3 class="modal-title">Confirm Delete</h3>
            <button onclick="closeDeleteContestantModal()" class="close-btn">&times;</button>
        </div>
        <div class="modal-body">
            <p class="delete-message">Are you sure you want to delete this contestant? This action cannot be undone.</p>
            <p id="deleteContestantName" class="delete-item-name"></p>
            <input type="hidden" id="deleteId">
            <div class="modal-actions">
                <button type="button" onclick="closeDeleteContestantModal()" class="cancel-btn">Cancel</button>
                <button type="button" onclick="confirmDeleteContestant()" class="delete-btn">Delete</button>
            </div>
        </div>
    </div>
</div>

<style>
