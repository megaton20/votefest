<%- include('../partials/navback') %>
<!-- Admin Dashboard -->

<main class="container mx-auto px-4 pt-20 pb-16">

    <section class="container admin-dashboard">
        <div class="dashboard-header">
            
            <div class="dashboard-actions">
                <a href="/chat/admin" class="action-btn inbox-btn">
                    <span class="action-icon">📨</span>
                    <span class="action-text">View Inbox</span>
                 
                </a>
                <a href="/users" class="action-btn users-btn">
                    <span class="action-icon">👥</span>
                    <span class="action-text">Manage Users</span>
                </a>
            </div>
        </div>
    
        <div class="dashboard-stats">
            <div class="stat-card">
                <div class="stat-icon total-users">
                    <span>👥</span>
                </div>
                <div class="stat-content">
                    <h3 class="stat-number"><%= stats?.totalUsers || 0 %></h3>
                    <p class="stat-label">Total Users</p>
                </div>
                <div class="stat-trend">
                    <span class="trend-up">+12%</span>
                    <span>this month</span>
                </div>
            </div>
    
            <div class="stat-card">
                <div class="stat-icon total-messages">
                    <span>💬</span>
                </div>
                <div class="stat-content">
                    <h3 class="stat-number"><%= stats?.totalMessages || 0 %></h3>
                    <p class="stat-label">Total application</p>
                </div>
                <div class="stat-trend">
                    <span class="trend-up">+25%</span>
                    <span>this month</span>
                </div>
            </div>
    
            <div class="stat-card">
                <div class="stat-icon unread-messages">
                    <span>📩</span>
                </div>
                <div class="stat-content">
                    <h3 class="stat-number"><%= stats?.unreadMessages || 0 %></h3>
                    <p class="stat-label">Total votes</p>
                </div>
           
            </div>
    
            <div class="stat-card">
                <div class="stat-icon recent-activity">
                    <span>📊</span>
                </div>
                <div class="stat-content">
                    <h3 class="stat-number"><%= stats?.activeUsers || 0 %></h3>
                    <p class="stat-label">Active Users</p>
                </div>
                <div class="stat-trend">
                    <span class="trend-up">+8%</span>
                    <span>today</span>
                </div>
            </div>
        </div>
    
      
    </section>
</main>

<style>
/* Admin Dashboard Container */
.admin-dashboard {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px;
    background: transparent;
}

/* Dashboard Header */
.dashboard-header {
    background: rgba(17, 17, 17, 0.3);
    backdrop-filter: blur(25px);
    -webkit-backdrop-filter: blur(25px);
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 25px 30px;
    margin-bottom: 30px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.dashboard-title {
    font-family: 'Montserrat', sans-serif;
    font-weight: 800;
    font-size: 2rem;
    color: var(--text-light);
    display: flex;
    align-items: center;
    gap: 12px;
}

.dashboard-icon {
    font-size: 2.2rem;
}

.dashboard-actions {
    display: flex;
    gap: 15px;
}

.action-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 20px;
    border-radius: 12px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
    position: relative;
}

.inbox-btn {
    background: rgba(229, 57, 53, 0.2);
    color: var(--text-light);
    border: 1px solid rgba(229, 57, 53, 0.3);
}

.users-btn {
    background: rgba(156, 39, 176, 0.2);
    color: var(--text-light);
    border: 1px solid rgba(156, 39, 176, 0.3);
}

.action-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
}

.inbox-btn:hover {
    background: rgba(229, 57, 53, 0.35);
}

.users-btn:hover {
    background: rgba(156, 39, 176, 0.35);
}

.action-icon {
    font-size: 1.2rem;
}

.action-text {
    font-size: 0.95rem;
}

.action-badge {
    position: absolute;
    top: -8px;
    right: -8px;
    background: var(--accent-red);
    color: white;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 20px;
    min-width: 20px;
    text-align: center;
    box-shadow: 0 2px 10px rgba(229, 57, 53, 0.4);
    animation: pulse 2s infinite;
}

/* Dashboard Stats */
.dashboard-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
}

.stat-card {
    background: rgba(17, 17, 17, 0.2);
    backdrop-filter: blur(25px);
    -webkit-backdrop-filter: blur(25px);
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.03);
    padding: 25px;
    display: flex;
    align-items: center;
    gap: 20px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
    transition: all 0.3s ease;
}

.stat-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
}

.stat-icon {
    width: 60px;
    height: 60px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
}

.total-users {
    background: linear-gradient(135deg, rgba(33, 150, 243, 0.2), rgba(33, 150, 243, 0.4));
    border: 2px solid rgba(33, 150, 243, 0.3);
}

.total-messages {
    background: linear-gradient(135deg, rgba(76, 175, 80, 0.2), rgba(76, 175, 80, 0.4));
    border: 2px solid rgba(76, 175, 80, 0.3);
}

.unread-messages {
    background: linear-gradient(135deg, rgba(229, 57, 53, 0.2), rgba(229, 57, 53, 0.4));
    border: 2px solid rgba(229, 57, 53, 0.3);
}

.recent-activity {
    background: linear-gradient(135deg, rgba(156, 39, 176, 0.2), rgba(156, 39, 176, 0.4));
    border: 2px solid rgba(156, 39, 176, 0.3);
}

.stat-content {
    flex: 1;
}

.stat-number {
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--text-light);
    margin: 0;
    font-family: 'Montserrat', sans-serif;
}

.stat-label {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin: 5px 0 0 0;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.stat-trend {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 5px;
}

.trend-up {
    color: #4CAF50;
    font-weight: 600;
    font-size: 0.9rem;
}

.trend-down {
    color: #F44336;
    font-weight: 600;
    font-size: 0.9rem;
}

.trend-alert {
    color: #FF9800;
    font-weight: 600;
    font-size: 0.9rem;
}

.trend-good {
    color: #4CAF50;
    font-weight: 600;
    font-size: 0.9rem;
}

.stat-trend span:last-child {
    font-size: 0.8rem;
    color: var(--text-muted);
}

/* Dashboard Content */
.dashboard-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(500px, 1fr));
    gap: 30px;
}

@media (max-width: 1100px) {
    .dashboard-content {
        grid-template-columns: 1fr;
    }
}

.dashboard-section {
    background: rgba(17, 17, 17, 0.2);
    backdrop-filter: blur(25px);
    -webkit-backdrop-filter: blur(25px);
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.03);
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
}

.section-header {
    background: rgba(17, 17, 17, 0.3);
    padding: 20px 25px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.section-title {
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--text-light);
    margin: 0;
    display: flex;
    align-items: center;
    gap: 10px;
}

.section-icon {
    font-size: 1.2rem;
}

.section-link {
    color: var(--accent-red);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    transition: all 0.3s;
}

.section-link:hover {
    text-decoration: underline;
}

.section-content {
    padding: 20px;
    max-height: 400px;
    overflow-y: auto;
}

/* Messages List */
.messages-list {
    display: flex;
    flex-direction: column;
    gap: 15px;
}

.message-item {
    background: rgba(0, 0, 0, 0.1);
    border-radius: 12px;
    padding: 15px;
    display: flex;
    gap: 15px;
    transition: all 0.3s;
}

.message-item:hover {
    background: rgba(229, 57, 53, 0.05);
    transform: translateX(5px);
}

.avatar-small {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(229, 57, 53, 0.2), rgba(229, 57, 53, 0.4));
    border: 2px solid rgba(229, 57, 53, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    color: var(--text-light);
    flex-shrink: 0;
}

.message-details {
    flex: 1;
    min-width: 0;
}

.message-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
}

.message-user {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-light);
    margin: 0;
}

.message-time {
    font-size: 0.8rem;
    color: var(--text-muted);
    white-space: nowrap;
}

.message-preview {
    font-size: 0.9rem;
    color: rgba(245, 245, 245, 0.7);
    margin: 0 0 10px 0;
    line-height: 1.4;
}

.message-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.message-status {
    font-size: 0.75rem;
    padding: 3px 10px;
    border-radius: 12px;
    font-weight: 600;
}

.message-status.unread {
    background: rgba(229, 57, 53, 0.1);
    color: var(--accent-red);
}

.message-status.read {
    background: rgba(76, 175, 80, 0.1);
    color: #4CAF50;
}

.message-action {
    color: var(--accent-red);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 600;
    transition: all 0.3s;
}

.message-action:hover {
    text-decoration: underline;
}

/* Users List */
.users-list {
    display: flex;
    flex-direction: column;
    gap: 15px;
}

.user-item {
    background: rgba(0, 0, 0, 0.1);
    border-radius: 12px;
    padding: 15px;
    display: flex;
    gap: 15px;
    transition: all 0.3s;
}

.user-item:hover {
    background: rgba(156, 39, 176, 0.05);
    transform: translateX(5px);
}

.user-details {
    flex: 1;
}

.user-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-light);
    margin: 0 0 5px 0;
}

.user-username {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin: 0 0 10px 0;
}

.user-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.user-joined {
    font-size: 0.8rem;
    color: var(--text-muted);
}

.user-role {
    font-size: 0.75rem;
    padding: 3px 10px;
    border-radius: 12px;
    font-weight: 600;
    text-transform: uppercase;
}

.user-role.admin {
    background: rgba(229, 57, 53, 0.1);
    color: var(--accent-red);
}

.user-role.user {
    background: rgba(33, 150, 243, 0.1);
    color: #2196F3;
}

/* Empty States */
.empty-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    text-align: center;
}

.empty-icon {
    font-size: 3rem;
    margin-bottom: 15px;
    opacity: 0.5;
    color: var(--text-muted);
}

.empty-text {
    color: var(--text-muted);
    font-size: 1rem;
}

/* Scrollbar Styling */
.section-content::-webkit-scrollbar {
    width: 6px;
}

.section-content::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.1);
    border-radius: 10px;
}

.section-content::-webkit-scrollbar-thumb {
    background: rgba(229, 57, 53, 0.3);
    border-radius: 10px;
}

.section-content::-webkit-scrollbar-thumb:hover {
    background: rgba(229, 57, 53, 0.5);
}

/* Animations */
@keyframes pulse {
    0%, 100% {
        opacity: 0.7;
        transform: scale(1);
    }
    50% {
        opacity: 1;
        transform: scale(1.05);
    }
}

/* Responsive Design */
@media (max-width: 768px) {
    .admin-dashboard {
        padding: 15px;
    }
    
    .dashboard-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 20px;
        padding: 20px;
    }
    
    .dashboard-actions {
        width: 100%;
        flex-direction: column;
    }
    
    .action-btn {
        width: 100%;
        justify-content: center;
    }
    
    .dashboard-stats {
        grid-template-columns: 1fr;
    }
    
    .dashboard-content {
        grid-template-columns: 1fr;
    }
    
    .stat-card {
        padding: 20px;
    }
    
    .stat-number {
        font-size: 1.8rem;
    }
    
    .section-header {
        padding: 15px 20px;
    }
    
    .section-content {
        padding: 15px;
    }
}

@media (max-width: 576px) {
    .message-item,
    .user-item {
        flex-direction: column;
        gap: 10px;
    }
    
    .message-header,
    .user-meta {
        flex-direction: column;
        align-items: flex-start;
        gap: 5px;
    }
    
    .message-time {
        align-self: flex-start;
    }
    
    .avatar-small {
        align-self: flex-start;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Auto-refresh dashboard every 30 seconds
    setInterval(() => {
        // You can add AJAX refresh here if needed
        console.log('Dashboard auto-refresh');
    }, 30000);
    
    // Add click animations to stat cards
    const statCards = document.querySelectorAll('.stat-card');
    statCards.forEach(card => {
        card.addEventListener('click', function() {
            this.style.transform = 'scale(0.98)';
            setTimeout(() => {
                this.style.transform = '';
            }, 150);
        });
    });
});
</script>