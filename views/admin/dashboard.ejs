<script>
document.addEventListener('DOMContentLoaded', function() {
    loadContestants();
    
    // Auto-refresh dashboard every 30 seconds
    setInterval(() => {
        loadContestants();
    }, 30000);
    
    // Add click animations to stat cards
    const statCards = document.querySelectorAll('.stat-card');
    statCards.forEach(card => {
        card.addEventListener('click', function() {
            this.style.transform = 'scale(0.98)';
            setTimeout(() => {
                this.style.transform = '';
            }, 150);
        });
    });
});

// ============= LOAD CONTESTANTS =============
async function loadContestants() {
    const container = document.getElementById('contestants-list');
    
    try {
        const response = await fetch('/admin/contestants');
        const data = await response.json();
        
        if (data.success) {
            displayContestants(data.contestants);
        } else {
            container.innerHTML = '<div class="empty-section"><span class="empty-icon">🎭</span><p class="empty-text">Failed to load contestants</p></div>';
        }
    } catch (error) {
        console.error('Error loading contestants:', error);
        container.innerHTML = '<div class="empty-section"><span class="empty-icon">🎭</span><p class="empty-text">Error loading contestants</p></div>';
    }
}

function displayContestants(contestants) {
    const container = document.getElementById('contestants-list');
    
    if (!contestants || contestants.length === 0) {
        container.innerHTML = '<div class="empty-section"><span class="empty-icon">🎭</span><p class="empty-text">No contestants found</p></div>';
        return;
    }
    
    let html = '<div class="contestants-grid">';
    
    contestants.forEach(c => {
        html += `
            <div class="contestant-card-admin" data-id="${c.id}">
                <div class="contestant-image">
                    ${c.image_url ? `<img src="/img/c/${c.image_url}" alt="${c.name}" style="width:100%;height:100%;object-fit:cover;">` : '🎭'}
                </div>
                <div class="contestant-info">
                    <div class="contestant-name">
                        ${c.name}
                        <span class="contestant-number">#${c.contestant_number}</span>
                    </div>
                    <p class="contestant-bio">${c.bio || 'No bio provided'}</p>
                    <div class="contestant-stats">
                        <span class="contestant-votes">🗳️ ${c.votes || 0} votes</span>
                        <span class="contestant-rank">📊 Rank #${c.rank || 'N/A'}</span>
                    </div>
                    <div class="contestant-actions">
                        <button onclick="openEditContestantModal('${c.id}')" class="edit-btn">Edit</button>
                        <button onclick="openDeleteContestantModal('${c.id}', '${c.name}')" class="delete-btn-sm">Delete</button>
                    </div>
                </div>
            </div>
        `;
    });
    
    html += '</div>';
    container.innerHTML = html;
}

// ============= ADD CONTESTANT MODAL =============
function openAddContestantModal() {
    document.getElementById('addContestantModal').classList.add('show');
    document.body.style.overflow = 'hidden';
}

function closeAddContestantModal() {
    document.getElementById('addContestantModal').classList.remove('show');
    document.getElementById('addContestantForm').reset();
    document.body.style.overflow = '';
}

async function addContestant(event) {
    event.preventDefault();
    
    const formData = {
        name: document.getElementById('name').value,
        contestantNumber: document.getElementById('contestantNumber').value,
        bio: document.getElementById('bio').value,
        imageUrl: document.getElementById('imageUrl').value
    };
    
    const submitBtn = event.target.querySelector('.submit-btn');
    const originalText = submitBtn.textContent;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Adding...';
    
    try {
        const response = await fetch('/admin/contestants', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(formData)
        });
        
        const data = await response.json();
        
        if (data.success) {
            closeAddContestantModal();
            loadContestants();
            showNotification('Contestant added successfully!', 'success');
        } else {
            showNotification(data.error || 'Failed to add contestant', 'error');
        }
    } catch (error) {
        console.error('Error adding contestant:', error);
        showNotification('Error adding contestant', 'error');
    } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
    }
}

// ============= EDIT CONTESTANT MODAL =============
async function openEditContestantModal(contestantId) {
    try {
        const response = await fetch(`/admin/contestants/${contestantId}`);
        const data = await response.json();
        
        if (data.success) {
            const c = data.contestant;
            document.getElementById('editId').value = c.id;
            document.getElementById('editName').value = c.name;
            document.getElementById('editContestantNumber').value = c.contestant_number;
            document.getElementById('editBio').value = c.bio || '';
            document.getElementById('editImageUrl').value = c.image_url || '';
            
            document.getElementById('editContestantModal').classList.add('show');
            document.body.style.overflow = 'hidden';
        } else {
            showNotification('Failed to load contestant details', 'error');
        }
    } catch (error) {
        console.error('Error loading contestant:', error);
        showNotification('Error loading contestant', 'error');
    }
}

function closeEditContestantModal() {
    document.getElementById('editContestantModal').classList.remove('show');
    document.getElementById('editContestantForm').reset();
    document.body.style.overflow = '';
}

async function editContestant(event) {
    event.preventDefault();
    
    const contestantId = document.getElementById('editId').value;
    const formData = {
        name: document.getElementById('editName').value,
        contestantNumber: document.getElementById('editContestantNumber').value,
        bio: document.getElementById('editBio').value,
        imageUrl: document.getElementById('editImageUrl').value
    };
    
    const submitBtn = event.target.querySelector('.submit-btn');
    const originalText = submitBtn.textContent;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Updating...';
    
    try {
        const response = await fetch(`/admin/contestants/${contestantId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(formData)
        });
        
        const data = await response.json();
        
        if (data.success) {
            closeEditContestantModal();
            loadContestants();
            showNotification('Contestant updated successfully!', 'success');
        } else {
            showNotification(data.error || 'Failed to update contestant', 'error');
        }
    } catch (error) {
        console.error('Error updating contestant:', error);
        showNotification('Error updating contestant', 'error');
    } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
    }
}

// ============= DELETE CONTESTANT MODAL =============
function openDeleteContestantModal(contestantId, contestantName) {
    document.getElementById('deleteId').value = contestantId;
    document.getElementById('deleteContestantName').textContent = contestantName;
    document.getElementById('deleteContestantModal').classList.add('show');
    document.body.style.overflow = 'hidden';
}

function closeDeleteContestantModal() {
    document.getElementById('deleteContestantModal').classList.remove('show');
    document.getElementById('deleteId').value = '';
    document.getElementById('deleteContestantName').textContent = '';
    document.body.style.overflow = '';
}

async function confirmDeleteContestant() {
    const contestantId = document.getElementById('deleteId').value;
    
    const deleteBtn = document.querySelector('#deleteContestantModal .delete-btn');
    const originalText = deleteBtn.textContent;
    deleteBtn.disabled = true;
    deleteBtn.textContent = 'Deleting...';
    
    try {
        const response = await fetch(`/admin/contestants/${contestantId}`, {
            method: 'DELETE'
        });
        
        const data = await response.json();
        
        if (data.success) {
            closeDeleteContestantModal();
            loadContestants();
            showNotification('Contestant deleted successfully!', 'success');
        } else {
            showNotification(data.error || 'Failed to delete contestant', 'error');
        }
    } catch (error) {
        console.error('Error deleting contestant:', error);
        showNotification('Error deleting contestant', 'error');
    } finally {
        deleteBtn.disabled = false;
        deleteBtn.textContent = originalText;
    }
}

// ============= NOTIFICATION =============
function showNotification(message, type = 'info') {
    const notification = document.createElement('div');
    notification.className = `notification ${type}`;
    notification.textContent = message;
    
    Object.assign(notification.style, {
        position: 'fixed',
        top: '20px',
        right: '20px',
        padding: '15px 25px',
        borderRadius: '8px',
        color: '#fff',
        fontSize: '14px',
        fontWeight: '500',
        zIndex: '1100',
        animation: 'slideIn 0.3s ease'
    });
    
    if (type === 'success') {
        notification.style.background = 'linear-gradient(135deg, #4CAF50, #45a049)';
    } else if (type === 'error') {
        notification.style.background = 'linear-gradient(135deg, #F44336, #D32F2F)';
    } else {
        notification.style.background = 'linear-gradient(135deg, #2196F3, #1976D2)';
    }
    
    document.body.appendChild(notification);
    
    setTimeout(() => {
        notification.style.animation = 'slideOut 0.3s ease';
        setTimeout(() => notification.remove(), 300);
    }, 3000);
}

