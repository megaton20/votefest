<%- include('./partials/navback') %>

<main class="container mx-auto px-4 pt-20 pb-16 max-w-lg">


    <!-- Today's Stats -->
    <div class="grid grid-cols-2 gap-4 mb-8">
        <div class="bg-gradient-to-br from-purple-50 to-purple-100 rounded-xl p-5 text-center">
            <div class="text-3xl font-bold text-purple-700" id="stat-scanned"><%= stats.total_scanned_today %></div>
            <div class="text-xs text-purple-600 mt-1">Scanned Today</div>
        </div>
        <div class="bg-gradient-to-br from-pink-50 to-pink-100 rounded-xl p-5 text-center">
            <div class="text-3xl font-bold text-pink-700" id="stat-attendees"><%= stats.unique_attendees %></div>
            <div class="text-xs text-pink-600 mt-1">Attendees</div>
        </div>
    </div>

    <!-- Instructions Card -->
    <div class="bg-white rounded-2xl shadow-lg p-6 mb-6 border border-gray-100">
        <h2 class="text-lg font-semibold text-gray-800 mb-4 flex items-center">
            <span class="w-1 h-6 bg-gradient-to-b from-purple-500 to-pink-500 rounded-full mr-3"></span>
            How to Scan
        </h2>
        
        <div class="space-y-4">
            <div class="flex items-center space-x-4">
                <div class="w-8 h-8 bg-purple-100 rounded-full flex items-center justify-center flex-shrink-0">
                    <span class="text-sm font-bold text-purple-600">1</span>
                </div>
                <p class="text-gray-600">Open your phone's camera app</p>
            </div>
            
            <div class="flex items-center space-x-4">
                <div class="w-8 h-8 bg-purple-100 rounded-full flex items-center justify-center flex-shrink-0">
                    <span class="text-sm font-bold text-purple-600">2</span>
                </div>
                <p class="text-gray-600">Point at the attendee's QR code</p>
            </div>
            
            <div class="flex items-center space-x-4">
                <div class="w-8 h-8 bg-purple-100 rounded-full flex items-center justify-center flex-shrink-0">
                    <span class="text-sm font-bold text-purple-600">3</span>
                </div>
                <p class="text-gray-600">Tap the notification that appears</p>
            </div>
            
            <div class="flex items-center space-x-4">
                <div class="w-8 h-8 bg-purple-100 rounded-full flex items-center justify-center flex-shrink-0">
                    <span class="text-sm font-bold text-purple-600">4</span>
                </div>
                <p class="text-gray-600">Confirm check-in on the page</p>
            </div>
        </div>
    </div>

    <!-- Manual Entry Fallback -->
    <div class="bg-white rounded-2xl shadow-lg p-6 border border-gray-100">
        <h2 class="text-lg font-semibold text-gray-800 mb-4 flex items-center">
            <span class="w-1 h-6 bg-gradient-to-b from-purple-500 to-pink-500 rounded-full mr-3"></span>
            Manual Entry
        </h2>
        
        <div class="space-y-3">
            <input type="text" id="manual-ticket-input" placeholder="Enter ticket ID" 
                   class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-purple-500 focus:border-transparent">
            <button onclick="manualVerify()" class="w-full py-3 bg-purple-600 text-white rounded-xl hover:bg-purple-700 transition font-medium">
                Verify Ticket
            </button>
        </div>
    </div>
</main>

<script>
function manualVerify() {
    const input = document.getElementById('manual-ticket-input').value.trim();
    if (input) {
        window.location.href = `/scanner/verify/${input}`;
    }
}

// Auto-refresh stats every 30 seconds
setInterval(async () => {
    try {
        const response = await fetch('/scanner/stats');
        const data = await response.json();
        if (data.success) {
            document.getElementById('stat-scanned').textContent = data.stats.total_scanned_today;
            document.getElementById('stat-attendees').textContent = data.stats.unique_attendees;
        }
    } catch (error) {
        console.error('Stats refresh error:', error);
    }
}, 30000);
</script>