<%- include('../partials/navback') %>

<main class="container mx-auto px-4 pt-20 pb-16 max-w-md">
    <div class="bg-white rounded-2xl shadow-xl p-8 text-center">
        <div class="w-24 h-24 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-12 h-12 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </div>
        
        <h1 class="text-2xl font-bold text-red-600 mb-2">Error</h1>
        <p class="text-gray-600 mb-6"><%= error %></p>
        
        <a href="/scanner" class="inline-block px-6 py-3 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition">
            Try Again
        </a>
    </div>
</main>