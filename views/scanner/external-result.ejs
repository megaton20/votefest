<%- include('../partials/navback') %>

<main class="container mx-auto px-4 pt-20 pb-16 max-w-md">
    <div class="bg-white rounded-2xl shadow-xl p-8 text-center">
        <div class="w-24 h-24 bg-yellow-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-12 h-12 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
        </div>
        
        <h1 class="text-2xl font-bold text-yellow-600 mb-2">Ticket Already Used</h1>
        <p class="text-gray-600 mb-2">This ticket was checked in at:</p>
        <p class="font-medium text-gray-800 mb-6"><%= new Date(checkedInAt).toLocaleString() %></p>
        
        <a href="/scanner" class="inline-block px-6 py-3 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition">
            Scan Another
        </a>
    </div>
</main>