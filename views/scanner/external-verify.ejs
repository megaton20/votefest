<%- include('../partials/navback') %>

<main class="container mx-auto px-4 pt-20 pb-16 max-w-md">
    <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
        <!-- Status Header -->
        <div class="bg-gradient-to-r from-purple-600 to-pink-600 p-6 text-center">
          
            <h1 class="text-2xl font-bold text-white">Ticket Scan</h1>
            <p class="text-purple-100 text-sm mt-1">Verify and check in attendee</p>
        </div>

        <div style="border-bottom: 1px dotted #333;">
                <div class="bg-gray-50 p-4 rounded-lg mb-4 ">
                    <img src="<%= ticket.qr_code_url %>" alt="QR Code" class="w-48 h-48 mx-auto">
                </div>
            
        </div>
        <!-- Ticket Details -->
        <div class="p-6">
            <div class="bg-gray-50 rounded-xl p-5 mb-6">
                <div class="flex justify-between items-center mb-4 pb-4 border-b border-gray-200">
                    <span class="text-sm text-gray-500">Ticket Type</span>
                    <span class="px-4 py-1.5 bg-<%= 
                        ticket.ticket_type === 'vvip' ? 'yellow' : 
                        ticket.ticket_type === 'vip' ? 'purple' : 
                        ticket.ticket_type === 'regular' ? 'gray' : 'blue' 
                    %>-100 text-<%= 
                        ticket.ticket_type === 'vvip' ? 'yellow' : 
                        ticket.ticket_type === 'vip' ? 'purple' : 
                        ticket.ticket_type === 'regular' ? 'gray' : 'blue' 
                    %>-700 rounded-full text-sm font-medium">
                        <%= ticket.ticket_type.toUpperCase() %>
                    </span>
                </div>

                <div class="space-y-3">
                    <div class="flex justify-between">
                        <span class="text-gray-500">Attendee:</span>
                        <span class="font-semibold text-gray-800"><%= ticket.attendee_name %></span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-500">Email:</span>
                        <span class="text-gray-800"><%= ticket.attendee_email %></span>
                    </div>
                    <% if (ticket.wallet_account) { %>
                    <div class="flex justify-between">
                        <span class="text-gray-500">Wallet:</span>
                        <span class="font-mono text-sm text-purple-600"><%= ticket.wallet_account %></span>
                    </div>
                    <% } %>
                    <div class="flex justify-between pt-3 border-t border-gray-200">
                        <span class="text-gray-500">Purchased by:</span>
                        <span class="font-medium text-gray-800"><%= ticket.purchaser_name %></span>
                    </div>
                </div>
            </div>

            <!-- Action Button -->
            <button onclick="processCheckin('<%= ticket.id %>')" 
                    id="checkin-btn"
                    class="w-full py-4 bg-red-500 text-white rounded-xl text-lg font-semibold hover:bg-green-700 transition flex items-center justify-center space-x-2 shadow-lg hover:shadow-xl">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Confirm Check-in</span>
            </button>

            <p class="text-center text-xs text-gray-500 mt-4">
                By confirming, you verify that this attendee has arrived
            </p>
        </div>
    </div>
</main>


<!-- Socket.IO -->
<script src="/socket.io/socket.io.js"></script>
<script>
const socket = io();

async function processCheckin(ticketId) {
    const btn = document.getElementById('checkin-btn');
    const originalText = btn.innerHTML;
    
    // Disable button and show loading
    btn.disabled = true;
    btn.innerHTML = '<span class="inline-block animate-spin mr-2">⏳</span> Processing...';
    
    try {
        const response = await fetch('/scanner/scan', {
            method: 'POST',
            headers: { 
                'Content-Type': 'application/json',
                'Accept': 'application/json'
            },
            body: JSON.stringify({ 
                ticketId: ticketId,
                action: 'entry' 
            })
        });
        
        const data = await response.json();
        
        if (data.success) {
            // Success - redirect to success page
            window.location.href = '/scanner/success?name=' + encodeURIComponent('<%= ticket.attendee_name %>');
        } else {
            // Show error
            alert(data.message || 'Check-in failed');
            btn.disabled = false;
            btn.innerHTML = originalText;
        }
    } catch (error) {
        console.error('Check-in error:', error);
        alert('Error processing check-in. Please try again.');
        btn.disabled = false;
        btn.innerHTML = originalText;
    }
}


